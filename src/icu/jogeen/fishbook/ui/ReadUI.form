<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="icu.jogeen.fishbook.ui.ReadUI">
  <grid id="27dc6" binding="contentPanel" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="638" height="448"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="aeab4" layout-manager="FlowLayout" hgap="3" vgap="1" flow-align="0">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="8" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="3a68a" class="javax.swing.JTextField" binding="tfPageNum">
            <constraints/>
            <properties>
              <columns value="5"/>
              <text value=""/>
            </properties>
          </component>
          <component id="80d2c" class="javax.swing.JLabel">
            <constraints/>
            <properties>
              <text value="/"/>
            </properties>
          </component>
          <component id="ee34" class="javax.swing.JLabel" binding="labTotalPages">
            <constraints/>
            <properties>
              <text value="0"/>
            </properties>
          </component>
          <component id="f3a37" class="javax.swing.JButton" binding="btnJump">
            <constraints/>
            <properties>
              <text value="Go"/>
              <margin top="1" left="4" bottom="1" right="4"/>
            </properties>
          </component>
          <component id="dab76" class="javax.swing.JButton" binding="btnPre">
            <constraints/>
            <properties>
              <text value="&lt;"/>
              <toolTipText value="←"/>
              <margin top="1" left="4" bottom="1" right="4"/>
            </properties>
          </component>
          <component id="eed58" class="javax.swing.JButton" binding="btnNext">
            <constraints/>
            <properties>
              <text value="&gt;"/>
              <toolTipText value="→"/>
              <margin top="1" left="4" bottom="1" right="4"/>
            </properties>
          </component>
          <component id="58f81" class="javax.swing.JLabel" binding="labBookName">
            <constraints/>
            <properties>
              <text value="******"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="a6c56" layout-manager="FlowLayout" hgap="3" vgap="1" flow-align="0">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="8" fill="2" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="a1b2c" class="javax.swing.JTextField" binding="tfSearch">
            <constraints/>
            <properties>
              <columns value="10"/>
            </properties>
          </component>
          <component id="d3e4f" class="javax.swing.JButton" binding="btnSearch">
            <constraints/>
            <properties>
              <text value="搜索"/>
              <margin top="1" left="4" bottom="1" right="4"/>
            </properties>
          </component>
          <component id="g5h6i" class="javax.swing.JButton" binding="btnBack">
            <constraints/>
            <properties>
              <text value="回退"/>
              <margin top="1" left="4" bottom="1" right="4"/>
            </properties>
          </component>
        </children>
      </grid>
      <component id="5fcfc" class="javax.swing.JTextPane" binding="txContetnt">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="6" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="150" height="50"/>
          </grid>
        </constraints>
        <properties>
          <text value="初始化设置请  Setttings-&gt;Tools-&gt;FishBook Config 配置中选择书籍"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
